   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cleanign gaze data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "metadata": {},
   "outputs": [],
   "source": [
    "gaze_data_path = \"/home/s243636/master-thesis/supp/gaze/sub-OE002/ses-Hellerup/gaze2.csv\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loading Gaze data...\n",
      "Gaze data cleaned successfully.\n"
     ]
    }
   ],
   "source": [
    "print(\"Loading Gaze data...\")\n",
    "try:\n",
    "    # -------------------------------\n",
    "    # LOAD\n",
    "    # -------------------------------\n",
    "    gaze_data = pd.read_csv(gaze_data_path)\n",
    "\n",
    "    gaze_data['Seconds'] = pd.to_datetime(gaze_data['Seconds'], errors='coerce')\n",
    "    gaze_data = gaze_data.rename(columns={'Seconds': 'DateTime'})\n",
    "    gaze_data = gaze_data[['DateTime','GazeX','GazeY']]\n",
    "\n",
    "    # -------------------------------\n",
    "    # SORT + CLEAN BASICS\n",
    "    # -------------------------------\n",
    "    gaze_data = gaze_data.sort_values(\"DateTime\")\n",
    "    gaze_data = gaze_data.dropna(subset=['GazeX','GazeY'])\n",
    "\n",
    "    # -------------------------------\n",
    "    # REMOVE OUT-OF-BOUNDS VALUES\n",
    "    # (adjust resolution if needed)\n",
    "    # -------------------------------\n",
    "    gaze_data = gaze_data[\n",
    "        (gaze_data['GazeX'] >= 0) & (gaze_data['GazeX'] <= 1280) &\n",
    "        (gaze_data['GazeY'] >= 0) & (gaze_data['GazeY'] <= 720)\n",
    "    ]\n",
    "\n",
    "    # -------------------------------\n",
    "    # REMOVE LARGE TIME GAPS\n",
    "    # -------------------------------\n",
    "    gaze_data['dt'] = gaze_data['DateTime'].diff().dt.total_seconds()\n",
    "    gaze_data = gaze_data[gaze_data['dt'] < 0.2]  # keep continuous data (~25 Hz)\n",
    "\n",
    "    # -------------------------------\n",
    "    # REMOVE EXTREME JUMPS\n",
    "    # -------------------------------\n",
    "    gaze_data['dx'] = gaze_data['GazeX'].diff()\n",
    "    gaze_data['dy'] = gaze_data['GazeY'].diff()\n",
    "\n",
    "    gaze_data['jump'] = np.sqrt(gaze_data['dx']**2 + gaze_data['dy']**2)\n",
    "\n",
    "    gaze_data = gaze_data[gaze_data['jump'] < gaze_data['jump'].quantile(0.99)]\n",
    "\n",
    "    # -------------------------------\n",
    "    # SMOOTH (Savitzky-Golay)\n",
    "    # -------------------------------\n",
    "    # Window must be odd and smaller than data length\n",
    "    window = 21 if len(gaze_data) > 21 else len(gaze_data) - 1\n",
    "    if window % 2 == 0:\n",
    "        window -= 1\n",
    "\n",
    "    gaze_data['GazeX'] = savgol_filter(gaze_data['GazeX'], window, 3)\n",
    "    gaze_data['GazeY'] = savgol_filter(gaze_data['GazeY'], window, 3)\n",
    "\n",
    "    # -------------------------------\n",
    "    # CLEAN UP\n",
    "    # -------------------------------\n",
    "    gaze_data = gaze_data.drop(columns=['dt','dx','dy','jump'])\n",
    "\n",
    "    print(\"Gaze data cleaned successfully.\")\n",
    "\n",
    "except:\n",
    "    print(f\"There is no Gaze data for this session\")\n",
    "    print(\"Adding empty Gaze data...\")\n",
    "    gaze_data = pd.DataFrame(columns=[\"DateTime\",\"GazeX\",\"GazeY\"])"
   ]
  },
